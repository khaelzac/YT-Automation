{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/process-job",
      "destination": "/api/process-job"
    },
    {
      "source": "/schedule-scan",
      "destination": "/api/schedule-scan"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ],
  "crons": [
    {
      "path": "/api/process-job",
      "schedule": "0 0 * * *"
    }
  ]
}
