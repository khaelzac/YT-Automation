PORT=4000
NODE_ENV=development
# Supabase pooled connection (used by Prisma Client at runtime)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-POOLER-HOST]:6543/postgres?pgbouncer=true&connection_limit=1"
# Supabase direct connection (used by Prisma Migrate)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
CLIENT_ORIGIN="http://localhost:3000"
CRON_SECRET=""
CRON_MAX_JOBS_PER_RUN=1
CRON_TIME_BUDGET_MS=45000
SCRIPT_RETRY_MAX=5
SCRIPT_RETRY_BASE_DELAY_MS=800
RATE_LIMIT_DELAY_SECONDS=120
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"
GROQ_MAX_TOKENS=2600
VIDEO_PROVIDER_API_KEY=""
XAI_API_KEY=""
XAI_VIDEO_MODEL="grok-imagine-video"
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REDIRECT_URI="http://localhost:4000/api/auth/google/callback"
TOKEN_ENCRYPTION_KEY=""
